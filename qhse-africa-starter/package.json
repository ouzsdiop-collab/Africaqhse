{
  "name": "qhse-africa-starter",
  "private": true,
  "description": "QHSE Control — plateforme de pilotage SST, qualité et conformité (front + API)",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src e2e backend/src --max-warnings 500",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "build": "vite build",
    "build:analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "dev": "npx --yes concurrently -n api,web -c blue,green \"npm run dev:api\" \"npx --yes wait-on http://127.0.0.1:3001/api/health -t 120000 && npm run dev:front\"",
    "dev:reset": "npx --yes kill-port 3001 5173 && npm run dev",
    "dev:api": "npm run dev --prefix backend",
    "dev:front": "vite",
    "dev:front:serve": "npx --yes serve . -l 8080 --cors",
    "start:api": "npm start --prefix backend",
    "db:push": "npm run db:push --prefix backend",
    "db:generate": "npm run db:generate --prefix backend",
    "git:acp": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/git-acp.ps1",
    "generate-icons": "node scripts/generate-icons.mjs",
    "generate-guide": "node scripts/generate-user-guide.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "pdfkit": "^0.15.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.1",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@sentry/browser": "^8.55.1",
    "chart.js": "^4.5.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2"
  }
}
