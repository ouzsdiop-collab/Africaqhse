{
  "name": "qhse-africa-starter",
  "private": true,
  "description": "Front statique + backend dans /backend",
  "scripts": {
    "dev": "npx --yes concurrently -n api,web -c blue,green \"npm run dev:api\" \"npx --yes wait-on http://127.0.0.1:3001/api/health -t 120000 && npm run dev:front\"",
    "dev:reset": "npx --yes kill-port 3001 5173 && npm run dev",
    "dev:api": "npm run dev --prefix backend",
    "dev:front": "vite",
    "dev:front:serve": "npx --yes serve . -l 8080 --cors",
    "start:api": "npm start --prefix backend",
    "db:push": "npm run db:push --prefix backend",
    "db:generate": "npm run db:generate --prefix backend"
  },
  "devDependencies": {
    "vite": "^6.2.0"
  }
}
