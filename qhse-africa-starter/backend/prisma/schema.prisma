// PostgreSQL recommandé en production. Multi-organisations : table `tenants` + `tenant_members` ;
// les lignes métier portent `tenantId` (filtrage API via `req.qhseTenantId`).

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  /// active | suspended — les tenants suspendus ne sont plus proposés à la connexion.
  status    String   @default("active")
  /// Drapeaux SaaS (ex. modules activés) — géré par SUPER_ADMIN, exploitation future côté API.
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      TenantMember[]
  sites        Site[]
  isoEvidences IsoEvidence[]

  @@map("tenants")
}

model TenantMember {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Rôle au sein de l’organisation (MVP : souvent aligné sur le rôle global utilisateur).
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_members")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model Site {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  name      String
  code      String?
  address   String?
  createdAt DateTime @default(now())

  incidents            Incident[]
  audits               Audit[]
  actions              Action[]
  nonConformities      NonConformity[]
  controlledDocuments  ControlledDocument[]
  risks                Risk[]
  habilitations        Habilitation[]
  products             Product[]
  processes            Process[]
  trainingSessions     TrainingSession[]
  preventionPlans      PreventionPlan[]
  equipment            Equipment[]
  environmentalRecords EnvironmentalRecord[]
  nearMisses           NearMiss[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("sites")
}

model Risk {
  id          String   @id @default(cuid())
  tenantId    String?
  ref         String?
  title       String
  description String?
  category    String?
  gravity     Int?
  severity    Int      @default(1)
  probability Int      @default(1)
  gp          Int?
  status      String   @default("open")
  owner       String?
  siteId      String?
  siteRecord  Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  actions Action[]

  @@unique([tenantId, ref])
  @@index([tenantId])
  @@index([siteId])
  @@index([status])
  @@map("risks")
}

model Incident {
  id            String   @id @default(cuid())
  tenantId      String?
  ref           String
  type          String
  site          String
  siteId        String?
  siteRecord    Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  severity      String
  description   String?
  status        String   @default("Nouveau")
  createdAt     DateTime @default(now())
  location      String?
  causes        String?
  causeCategory String?
  photosJson    Json?
  responsible   String?

  linkedActions Action[]
  aiSuggestions AiSuggestion[]

  @@unique([tenantId, ref])
  @@index([tenantId])
  @@index([siteId])
  @@map("incidents")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  role         String
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  /// Identifiant métier optionnel (slug court) — login par e-mail reste la référence.
  clientCode String? @unique

  /// false = compte désactivé (connexion refusée).
  isActive Boolean @default(true)
  /// Statut SaaS canonique (migration progressive): INVITED | ACTIVE | SUSPENDED | LOCKED | EXPIRED | DELETED
  status   String  @default("ACTIVE")

  /// Premier login avec mot de passe provisoire : l’utilisateur doit changer avant accès complet.
  mustChangePassword Boolean @default(false)

  /// Horodatage de la dernière attribution d’un mot de passe provisoire (audit / support).
  temporaryPasswordCreatedAt DateTime?

  /// Mot de passe provisoire chiffré (AES-256-GCM), visible par l’admin tant que mustChangePassword=true.
  /// Effacé dès que l’utilisateur change son mot de passe.
  temporaryPasswordEncrypted String?

  lastLoginAt DateTime?

  onboardingCompleted Boolean @default(false)
  onboardingStep      Int     @default(0)

  /// MFA (TOTP) : secret chiffré (AES-256-GCM), actif seulement une fois confirmé par l'utilisateur.
  mfaEnabled         Boolean   @default(false)
  mfaSecretEncrypted String?
  mfaEnrolledAt      DateTime?
  /// Codes de secours à usage unique (hashés SHA-256, jamais stockés en clair), tableau JSON.
  mfaBackupCodesHash String?

  memberships                    TenantMember[]
  passwordResetTokens            PasswordResetToken[]
  assignedActions                Action[]               @relation("ActionAssignee")
  ownedProcesses                 Process[]              @relation("ProcessOwner")
  deputyProcesses                Process[]              @relation("ProcessDeputy")
  processReviews                 ProcessReview[]
  auditLogs                      AuditLog[]
  createdAiSuggestions           AiSuggestion[]         @relation("AiSuggestionCreatedBy")
  validatedAiSuggestions         AiSuggestion[]         @relation("AiSuggestionValidatedBy")
  createdControlledDocuments     ControlledDocument[]   @relation("ControlledDocumentCreatedBy")
  refreshTokens                  RefreshToken[]
  habilitations                  Habilitation[]
  assignedEquipment              Equipment[]
  trainingEnrollments            TrainingEnrollment[]
  createdIsoEvidences            IsoEvidence[]          @relation("IsoEvidenceCreatedBy")
  validatedIsoEvidences          IsoEvidence[]          @relation("IsoEvidenceValidatedBy")
  adminLogs                      AdminLog[]             @relation("AdminLogActor")
  feedbackEntries                Feedback[]             @relation("FeedbackCreatedBy")
  reportedEquipmentSignalements  EquipmentSignalement[] @relation("EquipmentSignalementReportedBy")
  validatedEquipmentSignalements EquipmentSignalement[] @relation("EquipmentSignalementValidatedBy")

  @@map("users")
}

model AdminLog {
  id          String   @id @default(cuid())
  actorUserId String
  actorUser   User     @relation("AdminLogActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  targetType  String?
  targetId    String?
  tenantId    String?
  action      String
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([tenantId, createdAt])
  @@index([action, createdAt])
  @@map("admin_logs")
}

/// Preuves ISO rattachées à une exigence du registre — persistance multi-tenant.
model IsoEvidence {
  id            String  @id @default(cuid())
  tenantId      String?
  tenant        Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requirementId String
  /// photo | document | audit | autre
  type          String
  fileUrl       String?
  content       String?
  /// pending | validated | rejected
  status        String  @default("pending")
  meta          Json    @default("{}")

  createdById   String
  createdBy     User    @relation("IsoEvidenceCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  validatedById String?
  validatedBy   User?   @relation("IsoEvidenceValidatedBy", fields: [validatedById], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now())
  validatedAt DateTime?

  @@index([tenantId])
  @@index([tenantId, requirementId])
  @@map("iso_evidences")
}

model Habilitation {
  id         String    @id @default(cuid())
  tenantId   String?
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteId     String?
  siteRecord Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)
  type       String
  level      String?
  validFrom  DateTime?
  validUntil DateTime?
  status     String    @default("active")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([tenantId])
  @@index([userId])
  @@index([siteId])
  @@index([status])
  @@map("habilitations")
}

/// Registre des équipements et EPI : contrôles périodiques, péremption, affectation.
model Equipment {
  id                         String                 @id @default(cuid())
  tenantId                   String?
  siteId                     String?
  siteRecord                 Site?                  @relation(fields: [siteId], references: [id], onDelete: SetNull)
  assignedUserId             String?
  assignedUser               User?                  @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  name                       String
  category                   String
  serialNumber               String?
  status                     String                 @default("in_service")
  lastControlDate            DateTime?
  nextControlDate            DateTime?
  maintenanceFrequencyMonths Int?
  signalements               EquipmentSignalement[]
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt

  @@index([tenantId])
  @@index([siteId])
  @@index([assignedUserId])
  @@index([status])
  @@map("equipment")
}

/// Signalement terrain sur un équipement (scan QR/NFC) : photo, pictogramme, note vocale, validation QHSE.
model EquipmentSignalement {
  id                String    @id @default(cuid())
  tenantId          String?
  equipmentId       String
  equipment         Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  siteId            String?
  reportedByUserId  String?
  reportedBy        User?     @relation("EquipmentSignalementReportedBy", fields: [reportedByUserId], references: [id], onDelete: SetNull)
  category          String
  severity          String    @default("medium")
  description       String?
  attachments       Json      @default("[]")
  status            String    @default("pending")
  qhseComment       String?
  validatedByUserId String?
  validatedBy       User?     @relation("EquipmentSignalementValidatedBy", fields: [validatedByUserId], references: [id], onDelete: SetNull)
  validatedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([tenantId])
  @@index([equipmentId])
  @@index([siteId])
  @@index([status])
  @@map("equipment_signalements")
}

/// Catalogue des formations proposées (intitulé, obligation, périodicité de recyclage).
model TrainingCourse {
  id               String            @id @default(cuid())
  tenantId         String?
  title            String
  category         String?
  durationHours    Float?
  mandatory        Boolean           @default(false)
  recurrenceMonths Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  sessions         TrainingSession[]

  @@index([tenantId])
  @@map("training_courses")
}

/// Une occurrence planifiée/réalisée d'une formation (date, lieu, formateur).
model TrainingSession {
  id          String               @id @default(cuid())
  tenantId    String?
  courseId    String
  course      TrainingCourse       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  siteId      String?
  siteRecord  Site?                @relation(fields: [siteId], references: [id], onDelete: SetNull)
  date        DateTime
  location    String?
  trainer     String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  enrollments TrainingEnrollment[]

  @@index([tenantId])
  @@index([courseId])
  @@index([siteId])
  @@map("training_sessions")
}

/// Présence/résultat d'un utilisateur à une session, avec expiration calculée (recyclage).
model TrainingEnrollment {
  id             String          @id @default(cuid())
  tenantId       String?
  sessionId      String
  session        TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  attended       Boolean         @default(false)
  score          Float?
  certificateUrl String?
  completedAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([sessionId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([expiresAt])
  @@map("training_enrollments")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Action {
  id            String    @id @default(cuid())
  tenantId      String?
  title         String
  detail        String?
  status        String    @default("À lancer")
  owner         String?
  dueDate       DateTime?
  siteId        String?
  siteRecord    Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)
  assigneeId    String?
  assignee      User?     @relation("ActionAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  incidentId    String?
  incident      Incident? @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  auditId       String?
  audit         Audit?    @relation(fields: [auditId], references: [id], onDelete: SetNull)
  riskId        String?
  risk          Risk?     @relation(fields: [riskId], references: [id], onDelete: SetNull)
  /// Identifiant libre de l'exigence ISO liée (référentiel front, ex. "iso-45001:6.1.2") — traçabilité gap → action.
  requirementId String?
  createdAt     DateTime  @default(now())

  aiSuggestions AiSuggestion[]

  @@index([tenantId])
  @@index([incidentId])
  @@index([siteId])
  @@index([auditId])
  @@index([riskId])
  @@index([tenantId, riskId])
  @@index([tenantId, requirementId])
  @@map("actions")
}

model Audit {
  id               String    @id @default(cuid())
  tenantId         String?
  ref              String
  site             String
  siteId           String?
  siteRecord       Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)
  score            Int
  status           String
  checklist        Json?
  createdAt        DateTime  @default(now())
  autoReportSentAt DateTime?

  nonConformities     NonConformity[]
  actions             Action[]
  aiSuggestions       AiSuggestion[]
  controlledDocuments ControlledDocument[]

  @@unique([tenantId, ref])
  @@index([tenantId])
  @@index([siteId])
  @@map("audits")
}

model NonConformity {
  id            Int      @id @default(autoincrement())
  tenantId      String?
  title         String
  detail        String?
  status        String   @default("open")
  auditRef      String
  auditId       String?
  audit         Audit?   @relation(fields: [auditId], references: [id], onDelete: SetNull)
  siteId        String?
  siteRecord    Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  /// Identifiant libre de l'exigence ISO liée (référentiel front, ex. "iso-45001:6.1.2") — traçabilité gap → NC.
  requirementId String?
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([auditId])
  @@index([tenantId, requirementId])
  @@map("non_conformities")
}

model ImportHistory {
  id                   String   @id @default(cuid())
  tenantId             String?
  fileName             String
  fileType             String
  detectedDocumentType String?
  suggestedModule      String?
  suggestedModuleLabel String?
  moduleCreated        String?
  status               String
  warnings             Json?
  missingFields        Json?
  detectedHints        Json?
  confidence           Int?
  createdEntityId      String?
  createdEntityRef     String?
  userId               String?
  userName             String?
  errorMessage         String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  aiSuggestions AiSuggestion[]

  @@index([tenantId])
  @@map("import_history")
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String?
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  resource   String
  resourceId String
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@index([userId])
  @@map("audit_logs")
}

model Feedback {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  user      User?    @relation("FeedbackCreatedBy", fields: [userId], references: [id], onDelete: SetNull)
  type      String   @default("suggestion")
  page      String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("feedback")
}

model UserActivity {
  id           String    @id @default(cuid())
  tenantId     String
  userId       String
  actionCount  Int       @default(0)
  lastActionAt DateTime?

  @@unique([tenantId, userId])
  @@map("user_activity")
}

model AiSuggestion {
  id                String         @id @default(cuid())
  tenantId          String?
  type              String
  content           Json
  status            String         @default("pending_review")
  createdByUserId   String?
  createdByUser     User?          @relation("AiSuggestionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdBySource   String         @default("system")
  validatedByUserId String?
  validatedByUser   User?          @relation("AiSuggestionValidatedBy", fields: [validatedByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime       @default(now())
  validatedAt       DateTime?
  editedContent     Json?
  targetIncidentId  String?
  targetIncident    Incident?      @relation(fields: [targetIncidentId], references: [id], onDelete: SetNull)
  targetActionId    String?
  targetAction      Action?        @relation(fields: [targetActionId], references: [id], onDelete: SetNull)
  targetAuditId     String?
  targetAudit       Audit?         @relation(fields: [targetAuditId], references: [id], onDelete: SetNull)
  importHistoryId   String?
  importHistory     ImportHistory? @relation(fields: [importHistoryId], references: [id], onDelete: SetNull)
  riskRef           String?
  providerMeta      Json?

  @@index([tenantId])
  @@index([status, type])
  @@index([createdAt])
  @@map("ai_suggestions")
}

model ControlledDocument {
  id                String    @id @default(cuid())
  tenantId          String?
  name              String
  type              String
  path              String
  classification    String    @default("normal")
  siteId            String?
  site              Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)
  createdByUserId   String?
  createdBy         User?     @relation("ControlledDocumentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime  @default(now())
  mimeType          String?
  sizeBytes         Int?
  auditId           String?
  audit             Audit?    @relation(fields: [auditId], references: [id], onDelete: SetNull)
  productId         String?
  product           Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  fdsProductRef     String?
  isoRequirementRef String?
  riskRef           String?
  complianceTag     String?
  expiresAt         DateTime?
  responsible       String?
  updatedAt         DateTime  @updatedAt

  @@unique([tenantId, path])
  @@index([tenantId])
  @@index([siteId])
  @@index([classification])
  @@index([auditId])
  @@index([productId])
  @@index([tenantId, productId])
  @@map("controlled_documents")
}

/// Produit chimique — données structurées FDS (parse PDF + validation terrain).
model Product {
  id            String   @id @default(cuid())
  tenantId      String?
  name          String
  supplier      String?
  casNumber     String?
  ceNumber      String?
  hStatements   Json     @default("[]")
  pStatements   Json     @default("[]")
  ghsPictograms Json     @default("[]")
  vlep          String?
  storageClass  String?
  fdsFileUrl    String?
  siteId        String?
  siteRecord    Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  fdsDocuments ControlledDocument[]

  @@index([tenantId])
  @@index([siteId])
  @@index([casNumber])
  @@map("products")
}

/// Statut de conformité ISO par exigence (optionnellement par site).
model ConformityStatus {
  id            String   @id @default(cuid())
  tenantId      String?
  requirementId String
  status        String
  siteId        String?
  updatedAt     DateTime @updatedAt
  userId        String?

  @@unique([tenantId, requirementId, siteId])
  @@index([tenantId])
  @@index([requirementId])
  @@index([siteId])
  @@map("conformity_statuses")
}

/// Permis de travail — persistance API + signatures JSON.
model PermitToWork {
  id             String    @id @default(cuid())
  tenantId       String?
  ref            String
  siteId         String?
  type           String
  status         String    @default("pending")
  assignedTo     String?
  validFrom      DateTime?
  validUntil     DateTime?
  signaturesJson Json      @default("[]")
  payload        Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  preventionPlans PreventionPlan[]

  @@unique([tenantId, ref])
  @@index([siteId])
  @@index([status])
  @@map("permits_to_work")
}

/// Plan de prévention (coactivité entreprise extérieure) — inspection commune, risques d'interférence, signatures des deux parties.
model PreventionPlan {
  id                  String        @id @default(cuid())
  tenantId            String?
  ref                 String
  siteId              String?
  siteRecord          Site?         @relation(fields: [siteId], references: [id], onDelete: SetNull)
  externalCompanyName String
  externalContact     String?
  workDescription     String?
  startDate           DateTime?
  endDate             DateTime?
  status              String        @default("draft")
  inspectionDate      DateTime?
  risksJson           Json          @default("[]")
  clientSignature     Json?
  contractorSignature Json?
  permitId            String?
  permit              PermitToWork? @relation(fields: [permitId], references: [id], onDelete: SetNull)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([tenantId, ref])
  @@index([siteId])
  @@index([status])
  @@map("prevention_plans")
}

/// Suivi environnemental par site : déchets, eau, énergie (relevés périodiques).
model EnvironmentalRecord {
  id         String   @id @default(cuid())
  tenantId   String?
  siteId     String?
  siteRecord Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  type       String
  category   String?
  quantity   Float
  unit       String
  periodDate DateTime
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([siteId])
  @@index([type])
  @@index([periodDate])
  @@map("environmental_records")
}

/// Presque-accidents et retours d'expérience : événements sans dommage, analysés pour prévention.
model NearMiss {
  id               String   @id @default(cuid())
  tenantId         String?
  siteId           String?
  siteRecord       Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  title            String
  description      String?
  category         String?
  occurredAt       DateTime
  location         String?
  immediateActions String?
  lessonsLearned   String?
  status           String   @default("open")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId])
  @@index([siteId])
  @@index([status])
  @@index([occurredAt])
  @@map("near_misses")
}

/// Veille réglementaire — registre de textes légaux/normatifs suivis par le client, curé manuellement (résumé assisté par IA, validé par l'utilisateur).
model RegulatoryWatchEntry {
  id                 String    @id @default(cuid())
  tenantId           String?
  title              String
  country            String
  category           String?
  officialUrl        String?
  sourceText         String?
  summary            String?
  keyObligationsJson Json      @default("[]")
  effectiveDate      DateTime?
  impactStatus       String    @default("pending") // pending | applicable | not_applicable
  createdByUserId    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([tenantId, country])
  @@index([tenantId, impactStatus])
  @@map("regulatory_watch_entries")
}

model Process {
  id                String    @id @default(cuid())
  tenantId          String?
  siteId            String?
  siteRecord        Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)
  name              String
  /// management | realisation | support
  type              String    @default("realisation")
  purpose           String?
  ownerUserId       String?
  owner             User?     @relation("ProcessOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  deputyUserId      String?
  deputy            User?     @relation("ProcessDeputy", fields: [deputyUserId], references: [id], onDelete: SetNull)
  inputs            Json      @default("[]")
  outputs           Json      @default("[]")
  interestedParties Json      @default("[]")
  /// conforme | a_surveiller | critique | a_revoir
  status            String    @default("a_surveiller")
  reviewFrequency   String?
  lastReviewAt      DateTime?
  nextReviewAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  links          ProcessLink[]
  reviews        ProcessReview[]
  scoreSnapshots ProcessScoreSnapshot[]

  @@index([tenantId])
  @@index([siteId])
  @@map("processes")
}

model ProcessReview {
  id               String    @id @default(cuid())
  tenantId         String?
  processId        String
  process          Process   @relation(fields: [processId], references: [id], onDelete: Cascade)
  reviewedAt       DateTime  @default(now())
  reviewedByUserId String?
  reviewedBy       User?     @relation(fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  conclusion       String
  status           String?
  nextReviewAt     DateTime?
  createdAt        DateTime  @default(now())

  @@index([tenantId])
  @@index([processId])
  @@map("process_reviews")
}

model ProcessScoreSnapshot {
  id         String   @id @default(cuid())
  tenantId   String?
  processId  String
  process    Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
  score      Int
  capturedAt DateTime @default(now())

  @@index([tenantId])
  @@index([processId])
  @@map("process_score_snapshots")
}

model ProcessLink {
  id         String   @id @default(cuid())
  tenantId   String?
  processId  String
  process    Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
  /// risk | action | audit | document | indicator | incident | isoRequirement | evidence | conformityStatus
  linkedType String
  linkedId   String
  /// main | secondary | evidence | kpi | correctiveAction
  role       String?
  createdAt  DateTime @default(now())

  @@unique([processId, linkedType, linkedId])
  @@index([tenantId])
  @@index([processId])
  @@index([linkedType])
  @@map("process_links")
}
