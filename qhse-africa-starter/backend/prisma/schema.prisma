// PostgreSQL recommandé en production. V1 mono-tenant : `tenantId` optionnel sur les entités (pas de table tenants).

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Site {
  id        String   @id @default(cuid())
  /// Legacy (nullable) — plus de FK vers une table tenants.
  tenantId  String?
  name      String
  code      String?
  address   String?
  createdAt DateTime @default(now())

  incidents       Incident[]
  audits          Audit[]
  actions         Action[]
  nonConformities NonConformity[]
  controlledDocuments ControlledDocument[]
  risks               Risk[]
  habilitations       Habilitation[]
  products            Product[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("sites")
}

model Risk {
  id          String   @id @default(cuid())
  tenantId    String?
  ref         String?
  title       String
  description String?
  category    String?
  gravity     Int?
  severity    Int      @default(1)
  probability Int      @default(1)
  gp          Int?
  status      String   @default("open")
  owner       String?
  siteId      String?
  siteRecord  Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, ref])
  @@index([tenantId])
  @@index([siteId])
  @@index([status])
  @@map("risks")
}

model Incident {
  id            String   @id @default(cuid())
  tenantId      String?
  ref           String
  type          String
  site          String
  siteId        String?
  siteRecord    Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  severity      String
  description   String?
  status        String   @default("Nouveau")
  createdAt     DateTime @default(now())
  location      String?
  causes        String?
  causeCategory String?
  photosJson    String?
  responsible   String?

  linkedActions Action[]
  aiSuggestions AiSuggestion[]

  @@unique([tenantId, ref])
  @@index([tenantId])
  @@index([siteId])
  @@map("incidents")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  role         String
  passwordHash String?
  createdAt    DateTime @default(now())

  onboardingCompleted Boolean @default(false)
  onboardingStep      Int     @default(0)

  assignedActions            Action[]           @relation("ActionAssignee")
  auditLogs                  AuditLog[]
  createdAiSuggestions       AiSuggestion[]     @relation("AiSuggestionCreatedBy")
  validatedAiSuggestions     AiSuggestion[]     @relation("AiSuggestionValidatedBy")
  createdControlledDocuments ControlledDocument[] @relation("ControlledDocumentCreatedBy")
  refreshTokens              RefreshToken[]
  habilitations              Habilitation[]

  @@map("users")
}

model Habilitation {
  id         String    @id @default(cuid())
  tenantId   String?
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteId     String?
  siteRecord Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)
  type       String
  level      String?
  validFrom  DateTime?
  validUntil DateTime?
  status     String    @default("active")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([tenantId])
  @@index([userId])
  @@index([siteId])
  @@index([status])
  @@map("habilitations")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Action {
  id         String    @id @default(cuid())
  tenantId   String?
  title      String
  detail     String?
  status     String    @default("À lancer")
  owner      String?
  dueDate    DateTime?
  siteId     String?
  siteRecord Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)
  assigneeId String?
  assignee   User?     @relation("ActionAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  incidentId String?
  incident   Incident? @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  auditId    String?
  audit      Audit?    @relation(fields: [auditId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())

  aiSuggestions AiSuggestion[]

  @@index([tenantId])
  @@index([incidentId])
  @@index([siteId])
  @@index([auditId])
  @@map("actions")
}

model Audit {
  id               String    @id @default(cuid())
  tenantId         String?
  ref              String
  site             String
  siteId           String?
  siteRecord       Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)
  score            Int
  status           String
  checklist        Json?
  createdAt        DateTime  @default(now())
  autoReportSentAt DateTime?

  nonConformities       NonConformity[]
  actions               Action[]
  aiSuggestions         AiSuggestion[]
  controlledDocuments   ControlledDocument[]

  @@unique([tenantId, ref])
  @@index([tenantId])
  @@index([siteId])
  @@map("audits")
}

model NonConformity {
  id         Int      @id @default(autoincrement())
  tenantId   String?
  title      String
  detail     String?
  status     String   @default("open")
  auditRef   String
  auditId    String?
  audit      Audit?   @relation(fields: [auditId], references: [id], onDelete: SetNull)
  siteId     String?
  siteRecord Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([auditId])
  @@map("non_conformities")
}

model ImportHistory {
  id                   String   @id @default(cuid())
  tenantId             String?
  fileName             String
  fileType             String
  detectedDocumentType String?
  suggestedModule      String?
  suggestedModuleLabel String?
  moduleCreated        String?
  status               String
  warnings             Json?
  missingFields        Json?
  detectedHints        Json?
  confidence           Int?
  createdEntityId      String?
  createdEntityRef     String?
  userId               String?
  userName             String?
  errorMessage         String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  aiSuggestions AiSuggestion[]

  @@index([tenantId])
  @@map("import_history")
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String?
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  resource   String
  resourceId String
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@index([userId])
  @@map("audit_logs")
}

model AiSuggestion {
  id     String @id @default(cuid())
  tenantId String?
  type   String
  content Json
  status String @default("pending_review")
  createdByUserId String?
  createdByUser   User?   @relation("AiSuggestionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdBySource String  @default("system")
  validatedByUserId String?
  validatedByUser   User?   @relation("AiSuggestionValidatedBy", fields: [validatedByUserId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  validatedAt DateTime?
  editedContent Json?
  targetIncidentId String?
  targetIncident   Incident? @relation(fields: [targetIncidentId], references: [id], onDelete: SetNull)
  targetActionId String?
  targetAction   Action? @relation(fields: [targetActionId], references: [id], onDelete: SetNull)
  targetAuditId String?
  targetAudit   Audit? @relation(fields: [targetAuditId], references: [id], onDelete: SetNull)
  importHistoryId String?
  importHistory   ImportHistory? @relation(fields: [importHistoryId], references: [id], onDelete: SetNull)
  riskRef String?
  providerMeta Json?

  @@index([tenantId])
  @@index([status, type])
  @@index([createdAt])
  @@map("ai_suggestions")
}

model ControlledDocument {
  id     String @id @default(cuid())
  tenantId String?
  name   String
  type   String
  path   String
  classification String @default("normal")
  siteId String?
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)
  createdByUserId String?
  createdBy       User?   @relation("ControlledDocumentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  mimeType   String?
  sizeBytes  Int?
  auditId String?
  audit   Audit? @relation(fields: [auditId], references: [id], onDelete: SetNull)
  fdsProductRef String?
  isoRequirementRef String?
  riskRef String?
  complianceTag String?
  expiresAt DateTime?
  responsible String?
  updatedAt DateTime @updatedAt

  @@unique([tenantId, path])
  @@index([tenantId])
  @@index([siteId])
  @@index([classification])
  @@index([auditId])
  @@map("controlled_documents")
}

/// Produit chimique — données structurées FDS (parse PDF + validation terrain).
model Product {
  id             String   @id @default(cuid())
  name           String
  supplier       String?
  casNumber      String?
  ceNumber       String?
  hStatements    Json     @default("[]")
  pStatements    Json     @default("[]")
  ghsPictograms  Json     @default("[]")
  vlep           String?
  storageClass   String?
  fdsFileUrl     String?
  siteId         String?
  siteRecord     Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([siteId])
  @@index([casNumber])
  @@map("products")
}
