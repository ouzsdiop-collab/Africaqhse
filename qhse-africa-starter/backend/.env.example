# --- Développement local (sans Docker, sans PostgreSQL) ---
# Fichier SQLite créé dans prisma/ au premier `npx prisma db push`
DATABASE_URL="file:./prisma/dev.db"

# --- Alternative production (PostgreSQL) ---
# Remplacez le bloc datasource dans prisma/schema.prisma par provider = "postgresql"
# puis utilisez par exemple :
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/qhse_africa?schema=public"
# (ou : docker compose up -d si Docker Desktop est installé)

PORT=3001
NODE_ENV=development

# --- Authentification JWT (POST /api/auth/login, Bearer sur les requêtes) ---
# Minimum 16 caractères. Obligatoire en production.
JWT_SECRET=changez-moi-32-caracteres-minimum

# --- Durcissement API (SaaS) — voir src/lib/securityConfig.js ---
# Par défaut : en NODE_ENV=production, authentification obligatoire sur les routes requirePermission.
# REQUIRE_AUTH=false force le mode démo (pas d’utilisateur requis).
# REQUIRE_AUTH=true force l’auth même en développement.
# REQUIRE_AUTH=false

# En-tête X-User-Id (bootstrap démo) : désactivé par défaut en production.
# ALLOW_X_USER_ID=true pour le réactiver explicitement en prod (déconseillé sans réseau de confiance).
# ALLOW_X_USER_ID=false

# Origines CORS autorisées, séparées par des virgules (ex. https://app.example.com,http://localhost:5173).
# Vide = toutes origines (avertissement en console si NODE_ENV=production).
# CORS_ORIGINS=http://localhost:5173

# Corps JSON : limite 512 ko côté express.json (voir server.js).

# --- Phase 2 SaaS : rate limiting, proxy, corrélation, périmètre site (désactivé par défaut) ---
# TRUST_PROXY=true si l’API est derrière Nginx / load balancer (IP client pour express-rate-limit).
# RATE_LIMIT_MAX=400
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_AUTH_MAX=40
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# ENFORCE_SITE_SCOPE=false — true : filtre ?siteId= sur dashboard / rapports selon defaultSiteId (ADMIN/QHSE exempts).
# ENFORCE_DOCUMENT_SITE_SCOPE=false — true : liste / accès documents confidentiels selon defaultSiteId.
# BUSINESS_EVENT_AUDIT_LOG=false — true : journalise aussi les événements métier (business_event) dans audit_logs.

# --- Documents confidentiels (/api/controlled-documents) ---
# Stockage local : répertoire hors webroot (jamais servi en statique par Express).
# DOCUMENT_STORAGE_PATH=C:\\chemin\\vers\\storage\\controlled-documents
# Préparation S3 / objet : DOCUMENT_STORAGE_BACKEND=s3 (upload/lecture à brancher — 501 sinon).
# DOCUMENT_STORAGE_BACKEND=local
# Taille max upload (octets). Défaut : 26 214 400 (25 Mo).
# CONTROLLED_DOCUMENT_MAX_BYTES=26214400
# Secret dédié aux jetons de téléchargement (min. 16 caractères). Si absent : repli sur JWT_SECRET.
# DOCUMENT_ACCESS_SECRET=
# En production : HTTPS obligatoire devant l’API, pas d’exposition du dossier de fichiers, secrets en coffre (Vault, KMS, variables chiffrées hébergeur).

# --- IA suggestions (/api/ai-suggestions) — aucune écriture métier automatique ---
# Par défaut : heuristiques locales uniquement (pas d’appel cloud).
# AI_ALLOW_EXTERNAL=true + OPENAI_API_KEY pour activer OpenAI (JSON structuré — validation humaine toujours requise).
# AI_ALLOW_EXTERNAL=false
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Envoi e-mail (rapport PDF audit, etc.) — optionnel ---
# Sans SMTP_HOST + EMAIL_FROM, POST /api/audits/:id/send-report répond 503.
# Exemple fournisseur : Mailtrap, Brevo, SendGrid SMTP, ou serveur interne.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="QHSE Africa <noreply@example.com>"

# --- Automatisations V1 (synthèse hebdo + relances actions en retard) ---
# Clé optionnelle pour déclencher POST /api/automation/run sans session (cron, Task Scheduler).
# Sinon : utilisateur JWT avec rôle ADMIN ou QHSE.
# AUTOMATION_SECRET=

# Planificateur intégré (setInterval) — désactivé par défaut ; préférez un cron externe en prod si besoin.
# AUTOMATION_SCHEDULER=false
# Intervalle entre deux exécutions (ms), minimum 60 000. Défaut : 7 jours.
# AUTOMATION_INTERVAL_MS=604800000
# Délai avant le 1er passage après démarrage API (ms). Défaut : 120 000 (2 min).
# AUTOMATION_INITIAL_DELAY_MS=120000
