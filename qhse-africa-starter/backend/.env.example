# --- Base de données (PostgreSQL — requis pour ce dépôt) ---
# Développement local : docker compose up -d (voir docker-compose.yml) puis :
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/qhse_africa?schema=public"

# Migrations : depuis backend/
#   npx prisma migrate deploy
#   npm run db:seed

PORT=3001
NODE_ENV=development

# Origines CORS autorisées (whitelist, virgules) — priorité à CORS_ORIGINS, ALLOWED_ORIGINS reste en fallback
CORS_ORIGINS=http://localhost:5173
# ALLOWED_ORIGINS=http://localhost:5173

# --- Authentification JWT (POST /api/auth/login, Bearer sur les requêtes) ---
# Minimum 16 caractères. Obligatoire en production.
JWT_SECRET=changez-moi-32-caracteres-minimum

# Cookie httpOnly `qhse_refresh` : SameSite par défaut `lax` (meilleur couple SPA + API sur sous-domaines).
# `strict` ou `none` (ce dernier force Secure — front/API sur domaines totalement différents).
# AUTH_REFRESH_COOKIE_SAMESITE=lax
#
# Contrôle avancé (déploiements entreprise) :
# - AUTH_REFRESH_COOKIE_SECURE : force `Secure` indépendamment de NODE_ENV / SameSite (true|false).
#   Utile pour certains proxies ou environnements de préproduction.
# - AUTH_REFRESH_COOKIE_DOMAIN : ex. `.qhse.example.com` pour partager le cookie entre `app.` et `api.`.
#   Attention : n’utiliser que si vous maîtrisez tous les sous-domaines (risque de vol cookie si sous-domaine compromis).
# AUTH_REFRESH_COOKIE_SECURE=true
# AUTH_REFRESH_COOKIE_DOMAIN=.example.com

# --- Durcissement API (SaaS) — voir src/lib/securityConfig.js ---
# Par défaut : en NODE_ENV=production, authentification obligatoire sur les routes requirePermission.
# REQUIRE_AUTH=false force le mode sans utilisateur requis (développement uniquement).
# REQUIRE_AUTH=true force l’auth même en développement.
# REQUIRE_AUTH=false

# Multi-tenant : même avec REQUIRE_AUTH=false, la plupart des routes /api/* répondent 403 sans
# tenant résolu (Bearer + tid, ou X-User-Id hors production avec utilisateur connu). Exceptions :
# requireTenantContext.middleware.js → isApiTenantOptionalPath (health, auth, docs, stream signé, POST /api/fds/analyze, automation).

# En-tête X-User-Id : lu par isXUserIdAllowed() — autorisé hors production par défaut ; en production,
# uniquement si ALLOW_X_USER_ID=true (déconseillé hors réseau de confiance). En dev/test : false pour forcer le refus.
# ALLOW_X_USER_ID=true
# ALLOW_X_USER_ID=false

# --- Seed "client vierge" (base initiale client) ---
# Utilisé par: `npm run db:init:client` (dans backend/)
#
# Crée uniquement:
# - 1 organisation (tenant)
# - 1 compte admin + adhésion tenant (tenant_members)
# - Aucun incident/risque/audit/action/site/données démo
#
# Requis:
CLIENT_TENANT_SLUG=client
CLIENT_TENANT_NAME="Client"
CLIENT_ADMIN_EMAIL=admin@client.tld
CLIENT_ADMIN_NAME="Administrateur"
# Rôle global user + rôle tenantMember (string, ex: ADMIN)
CLIENT_ADMIN_ROLE=ADMIN
# En production: mot de passe fort (min 12) et non "demo"/"admin"/etc.
CLIENT_ADMIN_PASSWORD=

# --- Super admin plateforme (propriétaire QHSE Control) ---
# Crée/met à jour un compte global SUPER_ADMIN + membership dans un tenant interne.
# Commande: (depuis backend/) npm run admin:create
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Origines CORS (navigateur → API). En production, sans liste : les requêtes avec Origin sont refusées.
# Plusieurs origines : CORS_ORIGINS=https://votre-front.up.railway.app,http://localhost:5173
# Une seule URL front (Railway / Vercel) : FRONTEND_URL=https://votre-front.up.railway.app
# Les deux peuvent être combinés (dédupliqués).
# CORS_ORIGINS=http://localhost:5173
# FRONTEND_URL=

# Derrière le proxy Railway : recommandé pour le rate limiting (IP client).
# TRUST_PROXY=true

# Corps JSON : limite configurable (défaut 512 ko — voir server.js).
# JSON_BODY_LIMIT=512kb
# Connexion : corps validé par schéma Zod — erreurs 422 avec { code: "VALIDATION_ERROR", fieldErrors }.

# --- Observabilité API (optionnel) ---
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ENVIRONMENT=production
# Une ligne JSON structurée par requête HTTP terminée (méthode, chemin, statut, ms, requestId, userId).
# LOG_HTTP=1
# Timeout SQL pour GET /api/health/ready (ms, défaut 2500).
# HEALTH_DB_TIMEOUT_MS=2500

# --- Phase 2 SaaS : rate limiting, proxy, corrélation, périmètre site ---
# TRUST_PROXY=true si l’API est derrière Nginx / load balancer (IP client pour express-rate-limit).
# RATE_LIMIT_MAX=400
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_AUTH_MAX=40
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_UPLOAD_MAX=60
# RATE_LIMIT_UPLOAD_WINDOW_MS=900000
# ENFORCE_SITE_SCOPE=false — true : filtre ?siteId= sur dashboard / rapports selon defaultSiteId (ADMIN/QHSE exempts).
# ENFORCE_DOCUMENT_SITE_SCOPE=false — true : liste / accès documents confidentiels selon defaultSiteId.
# BUSINESS_EVENT_AUDIT_LOG=false — true : journalise aussi les événements métier (business_event) dans audit_logs.

# --- Documents confidentiels (/api/controlled-documents) ---
# Stockage : choisissez via STORAGE_DRIVER.
# - local : disque local (développement)
# - s3 : stockage S3 compatible (Railway, fichiers persistés après redéploiement)
# Sinon (rétrocompat) : S3 si S3_BUCKET est défini, local autrement.
# En S3 : le téléchargement passe par URLs présignées (aucune exposition de secrets).
# En local : fichiers sous DOCUMENT_STORAGE_PATH (ou backend/storage/controlled-documents par défaut).
STORAGE_DRIVER=local
# DOCUMENT_STORAGE_PATH=C:\\chemin\\vers\\storage\\controlled-documents
# Nom du bucket (Scaleway Object Storage, AWS S3, MinIO…).
# S3_BUCKET=qhse-controlled-docs
# S3_ENDPOINT=https://s3.fr-par.scw.cloud
# S3_REGION=fr-par
# Identifiants (ne jamais commiter) :
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL optionnel (affichage future uniquement)
S3_PUBLIC_URL=
# Région IAM / signature (ex. fr-par pour Scaleway, eu-west-3 pour AWS).
# Ex. MinIO local : http://127.0.0.1:9000
# Certains fournisseurs exigent le style chemin d’URL ; par défaut : true si S3_ENDPOINT est défini.
# S3_FORCE_PATH_STYLE=true
# Optionnel (à des fins d'affichage future) :
# S3_PUBLIC_URL=https://votre-public-url.example
# Taille max upload (octets). Défaut : 26 214 400 (25 Mo).
# CONTROLLED_DOCUMENT_MAX_BYTES=26214400
# Anciennes variables (rétrocompat) :
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# Secret dédié aux jetons de téléchargement (min. 16 caractères). Si absent : repli sur JWT_SECRET.
# DOCUMENT_ACCESS_SECRET=
# En production : HTTPS obligatoire devant l’API, pas d’exposition du dossier de fichiers, secrets en coffre (Vault, KMS, variables chiffrées hébergeur).

# --- IA suggestions (/api/ai-suggestions) — aucune écriture métier automatique ---
# Fournisseur : mock (défaut, pas d’appel cloud) | openai | mistral
AI_PROVIDER=mock
# Clés (requis si AI_PROVIDER=openai ou mistral) — fetch natif, pas de SDK.
OPENAI_API_KEY=
MISTRAL_API_KEY=
# OpenAI : modèle fixé côté code (gpt-4o-mini). Mistral : mistral-small-latest.
# Ancienne variable (rétrocompat lecture docs) — priorité à AI_PROVIDER.
# AI_ALLOW_EXTERNAL=true
# OPENAI_MODEL=gpt-4o-mini
# Routes : POST /api/ai-suggestions/suggest/root-causes { incidentId }, /suggest/actions { incidentId }, /suggest/risk-level { riskId }

# --- Envoi e-mail (rapport PDF audit, notifications, etc.) — optionnel ---
# Sans SMTP_HOST + SMTP_USER + (SMTP_FROM ou EMAIL_FROM), l’envoi est désactivé.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
# Obligatoire pour activer l’envoi (relay interne : renseigner un identifiant technique si besoin).
SMTP_USER=
SMTP_PASS=
# Adresse d’expédition (prioritaire sur EMAIL_FROM si les deux sont définis)
SMTP_FROM=
EMAIL_FROM="QHSE Control <noreply@example.com>"
# URL publique de l’application (liens dans e-mails, intégrations).
APP_URL=http://localhost:5173

# Fuseau du cron « résumé hebdo » (lundis 8h) — voir scheduleWeeklyEmailReport() ; défaut code : Africa/Abidjan
# CRON_TZ=Africa/Abidjan

# --- Automatisations V1 ---
# AUTOMATION_SECRET=
# AUTOMATION_SCHEDULER=false
# AUTOMATION_INTERVAL_MS=604800000
# AUTOMATION_INITIAL_DELAY_MS=120000

# --- Mistral AI (suggestions /api/ai — voir aiSuggestions.service.js) ---
MISTRAL_API_KEY=

# --- Documentation OpenAPI (Swagger UI sur /api/docs si NODE_ENV≠production ou SWAGGER_ENABLED=true) ---
# Désactivé par défaut en production. Si activé : accès ADMIN uniquement.
ENABLE_SWAGGER=false
# Variable legacy (rétrocompat) :
SWAGGER_ENABLED=false
