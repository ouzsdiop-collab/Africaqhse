# Copie ce fichier en .env.production et remplis les valeurs
# Ne jamais commiter .env.production dans Git

# URL de l'API backend (sans slash final)
VITE_API_BASE=https://TON-PROJET.up.railway.app

# Mode exploration (données locales, sans API) : désactivé en build production par défaut.
# Mettre à true uniquement pour une démo / sandbox publique.
# VITE_ALLOW_DEMO_MODE=true
